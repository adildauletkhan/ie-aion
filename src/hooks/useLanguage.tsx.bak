interface LanguageContextValue {
  language: Language;
  setLanguage: (lang: Language) => void;
  t: (key: string) => string;
  translateData: (value: string) => string;
}

const LanguageContext = createContext<LanguageContextValue | undefined>(undefined);

export function LanguageProvider({ children }: { children: ReactNode }) {
  const [language, setLanguage] = useState<Language>("ru");

  useEffect(() => {
    const stored = window.localStorage.getItem("capplan_language");
    if (stored === "ru" || stored === "en") {
      setLanguage(stored);
    }
  }, []);

  useEffect(() => {
    window.localStorage.setItem("capplan_language", language);
  }, [language]);

  const dataTranslations: Record<string, string> = {
    "Завод А": "Plant A",
    "Завод Б": "Plant B",
    "Завод В": "Plant C",
    "Завод Г": "Plant D",
    "Завод Д": "Plant E",
    "Атырауский НПЗ": "Atyrau Refinery",
    "Павлодарский НХЗ": "Pavlodar Refinery",
    "Шымкентский НПЗ": "Shymkent Refinery",
    "КТК: Атырау–Новороссийск": "CPC: Atyrau–Novorossiysk",
    "Атырау–Самара": "Atyrau–Samara",
    "Кенкияк–Кумколь": "Kenkiyak–Kumkol",
    "НПС Атырау": "Atyrau Pump Station",
    "НПС Кенкияк": "Kenkiyak Pump Station",
    "НПС Кумколь": "Kumkol Pump Station",
    "Тенгиз": "Tengiz",
    "Карачаганак": "Karachaganak",
    "Кашаган": "Kashagan",
    "Узень": "Uzen",
    "Жетыбай": "Zhetybai",
    "Каламкас": "Kalamkas",
    "Кенбай": "Kenbai",
    "Каражанбас": "Karazhanbas",
    "Активы КМГ (сводно)": "KMG assets (summary)",
    "Тенгизшевройл (TCO)": "Tengizchevroil (TCO)",
    "Карачаганак Петролиум Оперейтинг (KPO)": "Karachaganak Petroleum Operating (KPO)",
    "НКОК (NCOC)": "NCOC",
    "КазМунайГаз": "KazMunayGas",
    "Озенмунайгаз": "Ozenmunaigas",
    "Эмбамунайгаз": "Embamunaigas",
    "Каражанбасмунай": "Karazhanbasmunaigas",
    "Мангистаумунайгаз": "Mangystaumunaigas",
    "Казахойл Актобе": "Kazakhoil Aktobe",
    "Казгермунай": "Kazgermunai",
    "КазТрансОйл": "KazTransOil",
    "КТК (CPC Pipeline)": "CPC Pipeline",
    "КазТрансГаз": "KazTransGas",
    "Экспорт через КТК (Новороссийск)": "Export via CPC (Novorossiysk)",
    "Экспорт через Актауский порт": "Export via Aktau Port",
    "Экспорт в Китай по трубопроводам": "Export to China by pipelines",
    "Базовый сценарий": "Baseline scenario",
    "Рост GOV +20%": "GOV growth +20%",
    "Новый завод Е": "New Plant E",
    "Текущие мощности и планы без изменений": "Current capacities and plans without changes",
    "Увеличение гос. заказа на 20% по всем заводам": "Increase government order by 20% for all plants",
    "Добавление нового завода мощностью 2000": "Add new plant with capacity 2000",
    "Добыча (Upstream)": "Extraction (Upstream)",
    "Транспорт (Midstream)": "Transport (Midstream)",
    "Переработка (Downstream)": "Processing (Downstream)",
    "Экспорт (Crude)": "Export (Crude)",
    "Атырау": "Atyrau",
    "Актау": "Aktau",
    "Кызылорда": "Kyzylorda",
    "Аксай": "Aksai",
    "Актобе": "Aktobe",
    "Павлодар": "Pavlodar",
    "Туркестанская": "Turkestan",
    "Мангистауская": "Mangystau",
    "Актюбинская": "Aktobe Region",
    "Кызылординская": "Kyzylorda Region",
    "Казахстан": "Kazakhstan",
    "ЗКО": "West Kazakhstan",
    "Запад": "West",
    "Центр": "Center",
    "Каспий": "Caspian",
    "Добывающая скважина": "Production well",
    "Нагнетательная скважина": "Injection well",
    "АГЗУ": "AGZU",
    "УППН": "UPPN",
    "ВПН": "VPN",
    "ППН": "PPN",
    "КУН": "KUN",
    "РВС": "Tank farm",
    "ДНС": "DNS",
    "ЦПС": "CPS",
    "Сепаратор": "Separator",
    "Насос": "Pump",
    "Задвижка": "Gate valve",
    "Кран шаровой": "Ball valve",
    "Обратный клапан": "Check valve",
    "Нефтепровод межпромысловый": "Interfield oil pipeline",
    "Водовод (для закачки)": "Water injection pipeline",
    "Газопровод": "Gas pipeline",
    "Продуктопровод": "Product pipeline",
    "Коллектор сборный": "Gathering manifold",
    "Точка врезки": "Tie-in point",
    "Тройник": "Tee",
    "Переход (редукция диаметра)": "Reducer",
    "Запорный узел": "Shut-off node",
    "БПВ (Блок подготовки воды)": "Water prep unit (BPV)",
    "Очистные сооружения": "Treatment facilities",
    "Резервуар промывочной воды": "Wash water tank",
    "ГКС (Газокомпрессорная станция)": "Gas compressor station",
    "УКПГ (Установка комплексной подготовки газа)": "Gas treatment unit (UKPG)",
    "Факельная установка": "Flare stack",
    "БГ (Блок гребенки)": "Header block",
    "БКНС": "BKNS",
    "Отстойник": "Settling tank",
    "Емкость замерная": "Metering tank",
    "КНС (Кустовая насосная станция ППД)": "Cluster pump station (water injection)",
    "Блок дозирования реагентов": "Chemical dosing unit",
    "Водозаборная скважина": "Water intake well",
    "Насосная станция подкачки": "Booster pump station",
    "Система оборотного водоснабжения": "Circulating water system",
    "Насосная станция перекачки": "Transfer pump station",
    "ТП (Трансформаторная подстанция)": "Transformer substation",
    "ДЭС (Дизельная электростанция)": "Diesel power station",
    "ЛЭП (Линия электропередач)": "Power line",
    "РУ (Распределительное устройство)": "Switchgear",
    "Котельная": "Boiler house",
    "Теплообменник": "Heat exchanger",
    "Теплотрасса": "Heat pipeline",
    "Печь нагрева нефти": "Oil heater",
    "Теплообменная установка": "Heat exchange unit",
    "СИКН": "Oil metering unit",
    "УЗА": "UZA",
    "Расходомер": "Flow meter",
    "Пункт телемеханики": "Telemechanics point",
    "Шкаф управления": "Control cabinet",
    "Датчик": "Sensor",
    "Амбар (для сбора утечек/разливов)": "Spill pond",
    "Шламовый амбар": "Sludge pond",
    "Факел для утилизации газа": "Gas utilization flare",
    "Система улавливания паров нефти": "Vapor recovery system",
    "Пожарный резервуар": "Fire water tank",
    "Система пожаротушения": "Fire suppression system",
    "Аварийная емкость": "Emergency tank",
    "Дорога внутрипромысловая": "Field road",
    "Вахтовый поселок": "Shift camp",
    "База производственного обслуживания (БПО)": "Service base (BPO)",
    "Склад МТО": "MRO warehouse",
  };

  const value = useMemo<LanguageContextValue>(
    () => ({
      language,
      setLanguage,
      t: (key: string) => translations[language][key] ?? key,
      translateData: (value: string) =>
        language === "en" ? dataTranslations[value] ?? value : value,
    }),
    [language]
  );

  return <LanguageContext.Provider value={value}>{children}</LanguageContext.Provider>;
}

export function useLanguage() {
  const context = useContext(LanguageContext);
  if (!context) {
    throw new Error("useLanguage must be used within LanguageProvider");
  }
  return context;
}
